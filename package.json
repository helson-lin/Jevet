{
  "name": "Jevet",
  "version": "0.0.1",
  "main": "dist-electron/main/index.js",
  "description": "Image handler",
  "author": "helson-lin",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "type": "module",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "app:dir": "electron-builder --dir",
    "app:dist": "vue-tsc --noEmit && vite build && electron-builder",
    "rebuild": "electron-rebuild",
    "preview": "vite preview",
    "sharp:mac": "del-cli ./node_modules/sharp && npm install --platform=darwin --arch=arm64 sharp",
    "sharp:linux": "del-cli./node_modules/sharp && npm install --platform=linux --arch=x64 sharp"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^3.7.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "del-cli": "^6.0.0",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.4.2",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.6",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue": "^3.4.21",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.0.6"
  },
  "dependencies": {
    "@icon-park/vue-next": "^1.4.2",
    "@tailwindcss/vite": "^4.1.3",
    "@vueuse/core": "^13.1.0",
    "ant-design-vue": "^4.2.6",
    "electron-squirrel-startup": "^1.0.1",
    "onnxruntime-node": "^1.21.0",
    "pinia": "^3.0.2",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.1",
    "tailwindcss": "^4.1.3",
    "unzip": "^0.1.11",
    "vue-i18n": "^11.1.3"
  },
  "volta": {
    "node": "22.14.0"
  }
}
